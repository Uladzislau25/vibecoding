@startuml C4-Code
title ChefBot — Code Diagram (telegram-webhook recipe flow)

skinparam classAttributeIconSize 0
skinparam classBackgroundColor #F5F8FF
skinparam classBorderColor #2A4D9C

package "telegram-webhook" {
    class "index.ts" as Index <<entrypoint>> {
        - db: SupabaseClient
        - DEFAULT_CHAT_SETTINGS
        - GREETING_REPLIES / GRATITUDE_REPLIES / FAREWELL_REPLIES
        - BUTTON_COMMAND_MAP
        + Deno.serve(req): Response
        - upsertClient(message): Client
        - rateLimit(clientId): boolean
    }

    package "_handlers" {
        class "commands.ts" as Commands {
            + handleStart(chatId)
            + handlePreferences(db, chatId, clientId)
            + handleSave(db, chatId, clientId)
            + handleSaved(db, chatId, clientId)
            + handleList(db, chatId, clientId)
            + handleRandom(db, chatId, clientId)
            + handleWeek(db, chatId, clientId)
        }
        class "callback.ts" as Callback {
            + handleCallbackQuery(db, cb)
            - rate(clientId, recipeId, value)
            - save(clientId, recipeId)
            - clarify(chatId, payload)
        }
    }

    package "_lib" {
        class "recipe-flow.ts" as RecipeFlow {
            + processRecipeRequest(db, chatId, clientId, text, settings, sysPrompt, history, contextQuery)
            + saveBotReply(db, clientId, text, recipeId?, usage?)
            - escalate(clientId)
        }
        class "deepseek.ts" as DeepSeek {
            + generateRecipe(model, sysPrompt, history, text, temp, maxTokens): GeneratedRecipe
        }
    }
}

package "_shared" {
    class "supabase.ts" as Supabase <<api>> {
        + createAdminClient(): SupabaseClient
        + createUserClient(authHeader): SupabaseClient
    }
    class "telegram.ts" as Telegram <<api>> {
        + tgPost(method, payload)
        + sendMessage(chatId, text, markup?)
        + sendTyping(chatId)
        + recipeKeyboard(recipeId)
        + clarifyKeyboard(options)
    }
    class "embeddings.ts" as Embeddings {
        + createEmbedding(text, mode: "query"|"passage"): number[]
    }
    class "text.ts" as TextLib <<lib>> {
        + stripMarkdown(s)
        + detectCasual(s): "greeting"|"gratitude"|"farewell"|null
        + extractServings(s): number|null
        + pickRandom(arr)
    }
    class "http.ts" as HttpLib <<lib>> {
        + corsHeaders
        + jsonResponse(body, status)
    }
    class "types/index.ts" as Types <<types>> {
        + ClientSettings
        + ConversationMessage
        + TokenUsage
        + GeneratedRecipe
    }
}

Index --> Commands
Index --> Callback
Index --> RecipeFlow : processRecipeRequest()
Index --> Supabase : createAdminClient()
Index --> Telegram : sendMessage / sendTyping
Index --> TextLib : detectCasual / pickRandom
Index ..> Types

RecipeFlow --> DeepSeek : generateRecipe()
RecipeFlow --> Embeddings : createEmbedding()
RecipeFlow --> Telegram : sendMessage(.., recipeKeyboard|clarifyKeyboard)
RecipeFlow --> TextLib : stripMarkdown / extractServings
RecipeFlow ..> Types

Callback --> Supabase
Callback --> Telegram
Commands --> Supabase
Commands --> Telegram

DeepSeek ..> Types
Embeddings --> "Jina API" as Jina <<external>>
DeepSeek --> "DeepSeek API" as DS <<external>>
Telegram --> "Telegram Bot API" as TG <<external>>
Supabase --> "Postgres + RLS" as PG <<external>>

note right of RecipeFlow
  Алгоритм:
  1. semantic search (similarity >= 0.88) — отдать готовый рецепт
  2. иначе — LLM с structured output:
     • need_clarification → clarifyKeyboard
     • !can_help          → escalation_status='escalated'
     • can_help           → INSERT recipe + embedding,
                            recipeKeyboard (👍/👎/⭐)
  3. saveBotReply со счётом токенов
end note

@enduml
