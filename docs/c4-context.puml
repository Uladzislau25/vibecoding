@startuml C4-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title ChefBot — System Context Diagram

Person(client, "Клиент", "Пользователь Telegram, который спрашивает рецепты у бота")
Person(manager, "Менеджер", "Сотрудник поддержки, отвечает клиентам в эскалациях, ведёт заметки")
Person(admin, "Администратор", "Управляет менеджерами и ролями")

System(chefbot, "ChefBot", "Telegram-бот + админ-панель: подбор рецептов AI, эскалация на менеджера, история диалогов")

System_Ext(telegram, "Telegram Bot API", "Доставка сообщений и callback'ов")
System_Ext(deepseek, "DeepSeek API", "LLM для генерации рецептов (deepseek-v4-flash / v4-pro)")
System_Ext(jina, "Jina Embeddings API", "BGE-M3 эмбеддинги для семантического поиска рецептов")
System_Ext(google, "Google OAuth", "Аутентификация менеджеров в админ-панели")

Rel(client, telegram, "Пишет сообщения, нажимает кнопки", "HTTPS")
Rel(telegram, chefbot, "Webhook updates", "HTTPS/JSON")
Rel(chefbot, telegram, "sendMessage / sendChatAction", "HTTPS")

Rel(manager, chefbot, "Чат с клиентами, ответы, заметки, теги", "HTTPS")
Rel(admin, chefbot, "Управление ролями менеджеров", "HTTPS")

Rel(chefbot, deepseek, "Генерация рецептов и казуальных ответов", "HTTPS/JSON")
Rel(chefbot, jina, "Эмбеддинги query/passage", "HTTPS/JSON")
Rel(chefbot, google, "OAuth flow менеджеров", "OAuth 2.0")

SHOW_LEGEND()
@enduml
