@startuml C4-Component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title ChefBot — Component Diagram (support-admin + edge functions)

Person(manager, "Менеджер")
System_Ext(telegram, "Telegram Bot API")
System_Ext(deepseek, "DeepSeek API")
System_Ext(jina, "Jina Embeddings")
ContainerDb(db, "Supabase Postgres", "RLS + pgvector")
Container(auth, "Supabase Auth", "GoTrue")

Container_Boundary(admin, "support-admin (Next.js / FSD)") {
    Component(app_layer, "app/", "Next.js routes", "Pages: /, /chat/[id], /history, /recipes, /admin, /stats, /dashboard, /login")
    Component(widgets, "widgets/", "React Server/Client", "chat-list, messages-list, recipe-list — композиция фич/сущностей")
    Component(feat_assign, "features/assign-manager", "Server Actions", "assignManager(): upsert client_assignments + audit в messages_managers")
    Component(feat_reply, "features/chat-reply", "Server Actions + UI", "ReplyForm: вызов admin-reply edge function; addNote (sender_type='note')")
    Component(feat_escalation, "features/escalation", "Server Actions", "returnToBot(): escalation_status='normal'")
    Component(feat_tags, "features/client-tags", "Server Actions", "Управление массивом tags на clients")
    Component(feat_recipe_pick, "features/recipe-picker", "UI + actions", "Выбор готового рецепта для отправки клиенту")
    Component(feat_recipe_mgmt, "features/recipe-management", "Server Actions", "CRUD рецептов из админки")
    Component(feat_users, "features/user-management", "Server Actions", "Только admin: управление ролями менеджеров")
    Component(feat_auth, "features/auth", "Server Actions", "Google OAuth flow, password reset")
    Component(feat_settings, "features/chat-settings", "Server Actions", "model / temperature / system_prompt per client")
    Component(ent_client, "entities/client", "Domain types & queries", "Types, селекторы для clients/escalation_status")
    Component(ent_msg, "entities/message", "Domain types", "Message с sender_type=client|bot|manager|note")
    Component(ent_mgr, "entities/manager", "Domain types", "Manager + role")
    Component(ent_recipe, "entities/recipe", "Domain types", "Recipe + embedding")
    Component(shared_api, "shared/api", "Supabase client wrappers", "createSupabaseServer / Browser, edge function URL builder")
    Component(shared_ui, "shared/ui", "Tailwind components", "Базовые UI-примитивы")
    Component(shared_lib, "shared/lib", "Utils", "Форматирование, helpers")
}

Container_Boundary(edge, "Supabase Edge Functions") {
    Component(wh_index, "telegram-webhook/index.ts", "Deno", "Главный обработчик: upsert client, idempotency, rate-limit, маршрутизация команд")
    Component(wh_cmds, "_handlers/commands.ts", "Deno", "/start, /preferences, /save, /saved, /list, /random, /week")
    Component(wh_cb, "_handlers/callback.ts", "Deno", "callback_query: rate, save, clarify-выбор")
    Component(wh_recipe, "_lib/recipe-flow.ts", "Deno", "processRecipeRequest: семантический поиск → fallback на LLM → сохранение рецепта")
    Component(wh_deepseek, "_lib/deepseek.ts", "Deno", "Запрос к DeepSeek с structured output")
    Component(reply_index, "admin-reply/index.ts", "Deno", "Проверка JWT + assignment, отправка в Telegram, переход в manager_active")
    Component(addrec_index, "add-recipe/index.ts", "Deno", "Создание рецепта вручную с эмбеддингом")
    Component(sh_supabase, "_shared/api/supabase.ts", "Deno", "createAdminClient (service_role) / createUserClient")
    Component(sh_telegram, "_shared/api/telegram.ts", "Deno", "tgPost, sendMessage, sendTyping, клавиатуры")
    Component(sh_embed, "_shared/embeddings.ts", "Deno", "createEmbedding(text, mode)")
    Component(sh_text, "_shared/lib/text.ts", "Deno", "stripMarkdown, detectCasual, extractServings, pickRandom")
    Component(sh_http, "_shared/lib/http.ts", "Deno", "corsHeaders, jsonResponse")
}

Rel(manager, app_layer, "HTTPS")
Rel(app_layer, widgets, "")
Rel(widgets, feat_assign, "")
Rel(widgets, feat_reply, "")
Rel(widgets, feat_escalation, "")
Rel(widgets, feat_tags, "")
Rel(widgets, feat_recipe_pick, "")
Rel(widgets, ent_client, "")
Rel(widgets, ent_msg, "")
Rel(widgets, ent_mgr, "")
Rel(widgets, ent_recipe, "")
Rel(app_layer, feat_users, "")
Rel(app_layer, feat_recipe_mgmt, "")
Rel(app_layer, feat_auth, "")
Rel(app_layer, feat_settings, "")

Rel(feat_auth, auth, "OAuth", "HTTPS")
Rel(feat_assign, shared_api, "")
Rel(feat_reply, shared_api, "")
Rel(feat_escalation, shared_api, "")
Rel(shared_api, db, "PostgREST", "anon JWT + RLS")
Rel(feat_reply, reply_index, "POST + Bearer JWT", "HTTPS")
Rel(feat_recipe_mgmt, addrec_index, "POST", "HTTPS")

Rel(telegram, wh_index, "Webhook", "HTTPS")
Rel(wh_index, wh_cmds, "")
Rel(wh_index, wh_cb, "")
Rel(wh_index, wh_recipe, "")
Rel(wh_recipe, wh_deepseek, "")
Rel(wh_recipe, sh_embed, "")
Rel(wh_index, sh_supabase, "")
Rel(wh_index, sh_telegram, "")
Rel(wh_recipe, sh_telegram, "")
Rel(wh_index, sh_text, "")
Rel(reply_index, sh_supabase, "")
Rel(reply_index, sh_telegram, "")
Rel(reply_index, sh_http, "")
Rel(addrec_index, sh_supabase, "")
Rel(addrec_index, sh_embed, "")

Rel(sh_supabase, db, "service_role", "PostgREST")
Rel(sh_telegram, telegram, "REST", "HTTPS")
Rel(wh_deepseek, deepseek, "REST", "HTTPS")
Rel(sh_embed, jina, "REST", "HTTPS")

SHOW_LEGEND()
@enduml
